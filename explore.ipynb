   "source": [
    "import duckdb\n",
    "\n",
    "query = ''' \n",
    "    select\n",
    "    puzzle_number,\n",
    "    answer,\n",
    "    count(*) as times_used\n",
    "    from raw_wordle_words\n",
    "    group by puzzle_number ,answer\n",
    "    having count(*) > 1'''\n",
    "with duckdb.connect(\"./data/wordle.db\") as con:\n",
    "    display(con.query(query).df())\n",
    "    "
   ]
  }
